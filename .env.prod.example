# Copy this to .env.prod and fill real values, then use:
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# Godspeed admin
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=ChangeMeToASuperStrongPassword123!

# (Optional) External LLM keys
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# etc.

# WAHA secrets (must match the ones in docker-compose.prod.yml)
# WAHA_API_KEY=sha512:...
# WHATSAPP_HOOK_SECRET=...   (the part after ?secret= in the webhook url)
